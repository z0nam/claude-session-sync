# Copy to ~/.config/claude-remote.env and edit. The launcher sources this
# file if present, and the systemd/launchd units point at it explicitly.
#
# Every variable is optional. Leave a line commented out to fall back to the
# launcher's defaults.

# Directory the Remote Control session should start in. If unset, the
# launcher uses the current working directory at startup. For service-unit
# use, set this to your main project so the session lands in the right place
# after a reboot.
#CLAUDE_REMOTE_DIR="$HOME/code/my-project"

# Override the `claude` binary used. Useful if you have multiple installs
# (e.g. a beta build) and want the service to pin to one.
#CLAUDE_BIN="$HOME/.local/bin/claude"
